{
  "name": "pos",
  "private": true,
  "version": "0.1.0",
  "description": "Offline-first POS for hardware shop",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run rebuild:electron && vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "backend:typecheck": "tsc --noEmit -p tsconfig.backend.json",
    "backend:verify": "npm run rebuild:node && tsx backend/verify/run.ts",
    "backend:scenarios": "tsx backend/verify/scenarios.ts",
    "backend:e2e": "npm run rebuild:node && tsx backend/verify/e2e.ts",
    "backend:verify:all": "npm run rebuild:node && tsx backend/verify/all.ts && tsx backend/verify/api.ts && tsx backend/verify/run.ts && tsx backend/verify/e2e.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.25.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
